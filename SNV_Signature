  mutate(
    Corrected_Copy_Number = as.numeric(Corrected_Copy_Number),
    Ploidy                = as.numeric(Ploidy),
    cn_ratio              = Corrected_Copy_Number / Ploidy,
    annotation = case_when(
      Corrected_Call    == 'Intragenic CNV'          ~ 'Intragenic CNV',
      Corrected_MinorCN == 0                         ~ 'LOH',
      Chromosome != 'chrX' & cn_ratio >= 2           ~ 'HLAMP',
      Chromosome != 'chrX' & cn_ratio >= 1.5         ~ 'AMP',
      Chromosome != 'chrX' & cn_ratio <= 0.25        ~ 'DEL',
      Chromosome == 'chrX' & cn_ratio >= 1           ~ 'HLAMP',
      Chromosome == 'chrX' & cn_ratio >= 0.6         ~ 'AMP',
      Chromosome == 'chrX' & cn_ratio <= 0.125       ~ 'DEL',
      TRUE                                           ~ NA_character_
    ),
    # Intragenic CNV always takes priority over ratio-based classifications
    annotation = if_else(Corrected_Call == 'Intragenic CNV', 'Intragenic CNV', annotation)
  ) |>
  filter(!is.na(annotation))

