#' Load SigProfiler Activities, filter to given samples, normalise to
#' proportions, and return with a 'pluvicto' label column.
load_sbs_activities <- function(path, pluvicto_samples, other_samples) {
  sig <- read_tsv_df(path)
  sig <- sig[sig$Samples %in% c(pluvicto_samples, other_samples), ]
  mat <- sig[, 2:ncol(sig)]
  mat <- mat[, colSums(mat) != 0, drop = FALSE]
  mat <- mat / rowSums(mat)
  mat$id       <- sig$Samples
  mat$pluvicto <- ifelse(mat$id %in% pluvicto_samples, 'pluvicto', 'not_pluvicto')
  mat
}

sig2     <- load_sbs_activities(SIG_ACTIVITIES, pluvicto, other_wo_msi)
sbs_cols <- setdiff(colnames(sig2), c('id', 'pluvicto'))

# t-test for each SBS signature; collect results in a single pass
sbs_tests <- do.call(rbind, lapply(sbs_cols, function(sig_name) {
  p  <- sig2[sig2$pluvicto == 'pluvicto',     sig_name]
  np <- sig2[sig2$pluvicto == 'not_pluvicto', sig_name]
  tt <- t.test(p, np)
  data.frame(SBS             = sig_name,
             pvalue          = tt$p.value,
             pluvicto_avg    = tt$estimate[1],
             nonpluvicto_avg = tt$estimate[2])
}))

sig_hits <- sbs_tests[!is.na(sbs_tests$pvalue) & sbs_tests$pvalue < 0.05, ]
print(sig_hits)

# ── 8. File Export & TITAN Staging Utilities ─────────────────────────────────

#' Export per-sample SNV flat files, combined SNV, SV, and CNV files to the
#' collaboration directory. Directories are created automatically.
export_pluvicto_files <- function(samples, tumor_df, optimal_sol,
                                  base_cn, collab_base) {
  for (sub in c('SNV', 'SV', 'CNV')) dir.create(file.path(collab_base, sub), showWarnings = FALSE)

  for (s in samples) {
    # Individual SNV file
    write.table(tumor_df[tumor_df$sample_name == s, ],
                file.path(collab_base, 'SNV', paste0(s, '_SNV.txt')),
                sep = "\t", col.names = TRUE, row.names = FALSE, quote = FALSE)

    sol <- optimal_sol[optimal_sol$Sample == s, ]
    # SV file
    file.copy(
      from = file.path(base_cn, 'SV/output/TwoOverlap', s,
                       paste0(s, '.mergedTitan.sv.txt')),
      to   = file.path(collab_base, 'SV', paste0(s, '_SV.txt'))
    )
    # CNV segment file
    file.copy(
      from = file.path(base_cn, 'optimalTITAN',
                       paste0(s, '_cluster', sol$Cluster_Solution[1],
                              '.titan.ichor.seg.noSNPs.txt')),
      to   = file.path(collab_base, 'CNV', paste0(s, '_CNV.txt'))
    )
  }
  # Combined SNV table
  write.table(tumor_df[tumor_df$sample_name %in% samples, ],
              file.path(collab_base, 'SNV.txt'),
              sep = "\t", col.names = TRUE, row.names = FALSE, quote = FALSE)
}

