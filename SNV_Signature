#' Stage TITAN result files from a run directory into the optimalTITAN archive.
#' mode = 'folder' copies an entire cluster sub-directory;
#' mode = 'files'  copies only pattern-matched flat files (default).
stage_titan_results <- function(optimal_sol, titan_run_base, dest_base, mode = 'files') {
  for (i in seq_len(nrow(optimal_sol))) {
    s       <- optimal_sol$sample[i]
    pattern <- paste0(s, '_cluster', optimal_sol$cluster[i])
    from_base <- file.path(titan_run_base, paste0('titanCNA_ploidy', optimal_sol$phi[i]))

    if (mode == 'folder') {
      to_dir <- file.path(dest_base, pattern)
      dir.create(to_dir, showWarnings = FALSE)
      for (f in list.files(file.path(from_base, pattern), full.names = TRUE)) {
        file.copy(f, to_dir)
      }
    } else {
      for (f in list.files(from_base, pattern = pattern, full.names = TRUE)) {
        file.copy(f, dest_base)
      }
    }
  }
}

