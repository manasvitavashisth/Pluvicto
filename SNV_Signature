#' Extract patient ID from sample name (everything before the first underscore).
get_patient_id <- function(x) str_extract(x, "[^_]+")

#' Read a tab-separated flat file into a data.frame.
read_tsv_df <- function(path, ...) {
  as.data.frame(fread(path, header = TRUE, sep = "\t",
                      stringsAsFactors = FALSE, na.strings = c(".", "NA"), ...))
}

#' Generic boxplot with viridis fill and jitter.
plot_boxplot <- function(data, x_var, y_var, title, y_label) {
  ggplot(data, aes_string(x = x_var, y = y_var, fill = x_var)) +
    geom_boxplot() +
    scale_fill_viridis(discrete = TRUE, alpha = 0.6) +
    geom_jitter(color = "black", size = 0.4, alpha = 0.9) +
    theme_ipsum() +
    theme(legend.position = "none", plot.title = element_text(size = 11)) +
    ggtitle(title) + xlab(x_var) + ylab(y_label)
}

#' Count mitochondrial SNVs (Chr == 'chrM') from a per-sample SNV file.
count_mito_snvs <- function(sample_name, snv_dir) {
  path <- file.path(snv_dir, paste0(sample_name, '_Combined_TumorMutationCalls.txt'))
  snv  <- read_tsv_df(path)
  sum(snv$Chr == 'chrM', na.rm = TRUE)
}

