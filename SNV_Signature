#' Compute per-patient proportions of founder / shared / private mutations
#' from a clusters data.frame that contains a status column (pyclone_status or
#' lichee_status) and number_of_mutations.
#'
#' @param clusters   data.frame: patient, number_of_mutations, <status_col>
#' @param status_col column name for clone classification (string)
#' @return data.frame: patient, founder, shared, private
compute_clone_proportions <- function(clusters, status_col) {
  patients <- unique(clusters$patient)

  results <- lapply(patients, function(pt) {
    pt_data <- clusters[clusters$patient == pt, ]
    pt_data <- pt_data[!duplicated(pt_data$number_of_mutations), ]
    pt_data <- pt_data[!is.na(pt_data[[status_col]]), ]
    if (nrow(pt_data) == 0) return(NULL)

    pt_data$prop <- pt_data$number_of_mutations / sum(pt_data$number_of_mutations)

    mean_prop <- function(status) {
      mean(pt_data$prop[pt_data[[status_col]] == status], na.rm = TRUE)
    }

    data.frame(patient = pt,
               founder = mean_prop('Founder'),
               shared  = mean_prop('Shared'),
               private = mean_prop('Private'))
  })

  do.call(rbind, Filter(Negate(is.null), results))
}

