#' Annotate CNV calls for one sample against the gene panel using TITAN segments.
#' Returns a data.frame with one row per gene.
annotate_cnv_for_sample <- function(sample_id, genes, optimal_solution, titan_base) {
  sol      <- optimal_solution[optimal_solution$Sample == sample_id, ]
  seg_path <- file.path(titan_base,
    paste0(sample_id, '_cluster', sol$Cluster_Solution[1], '.titan.ichor.seg.noSNPs.txt'))
  seg    <- read_tsv_df(seg_path)
  ploidy <- as.numeric(sol[1, 3])

  rows <- lapply(seq_len(nrow(genes)), function(j) {
    g   <- genes[j, ]
    hit <- seg[seg$Chromosome == g$seqid &
                 seg$Start    <= g$start &
                 seg$End      >= g$end, ]

    if (nrow(hit) > 0) {
      row <- hit[1, ]
    } else {
      # Gene spans a breakpoint or is uncovered
      row <- data.frame(Chromosome     = g$seqid,
                        Start          = g$start,
                        End            = g$end,
                        Corrected_Call = 'Intragenic CNV')
    }
    row$Hugo_Symbol          <- g$gene_name
    row$Tumor_Sample_Barcode <- sample_id
    row$Ploidy               <- ploidy
    row
  })

  rbindlist(rows, fill = TRUE) |> as.data.frame()
}

