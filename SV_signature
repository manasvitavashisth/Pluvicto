#' Plot stacked barplot of SV signature proportions for one patient.
plot_patient_sig_bars <- function(data, pt_id, sig_cols) {
  pt      <- data[data$patient == pt_id, c(sig_cols, 'sample')]
  pt_long <- pivot_longer(pt, -sample, names_to = "variable", values_to = "value")
  pt_long <- pt_long[pt_long$value != 0, ]

  ggplot(pt_long, aes(x = sample, y = value, fill = variable)) +
    geom_bar(stat = "identity") +
    theme_minimal() +
    labs(x = "Sample", y = "Proportion",
         title = paste("SV Signatures –", pt_id)) +
    theme(axis.text.x = element_text(angle = 45, hjust = 1, size = 16),
          legend.text = element_text(size = 14))
}

sig_cols <- setdiff(colnames(sig_clonal_mat), c('sample', 'patient'))

for (pt in pluvicto_patient) {
  print(plot_patient_sig_bars(sig_clonal_mat, pt, sig_cols))
}

