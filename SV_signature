# ── Helper Functions ──────────────────────────────────────────────────────────

#' Extract patient ID (everything before the first underscore)
get_patient_id <- function(sample_names) str_extract(sample_names, "[^_]+")

#' Load and normalise a SigProfiler Activities file.
#' Returns a data.frame with proportions (rows sum to 1) and a `Samples` column.
load_sig_activities <- function(path) {
  df  <- as.data.frame(fread(path, header = TRUE, sep = "\t",
                              stringsAsFactors = FALSE, na.strings = c(".", "NA")))
  mat <- df[, 2:ncol(df)]
  mat <- mat[, colSums(mat) != 0, drop = FALSE]   # drop all-zero signatures
  mat <- mat / rowSums(mat)                         # normalise to proportions
  mat$Samples <- df$Samples
  mat
}

#' Load per-sample SV counts for a vector of sample names.
#' Returns a data.frame with columns: sample, Trans_Bal, Trans_Unbal,
#' TandemDup, Inversion_Bal, Inversion_Unbal, Deletion, InterChr.
load_sv_counts <- function(samples, sv_base_path) {
  sv_types <- c('Trans-Bal', 'Trans-Unbal', 'TandemDup',
                'Inversion-Bal', 'Inversion-Unbal', 'Deletion')

  results <- lapply(samples, function(s) {
    path <- file.path(sv_base_path, 'output', 'TwoOverlap', s,
                      paste0(s, '.mergedTitan.sv.txt'))
    sv   <- as.data.frame(fread(path, header = TRUE, sep = "\t",
                                 stringsAsFactors = FALSE, na.strings = c(".", "NA")))
    counts <- sapply(sv_types, function(t) sum(sv$CN_overlap_type == t, na.rm = TRUE))
    inter  <- sum(sv$type == 'InterChr', na.rm = TRUE)
    c(list(sample = s), as.list(counts), list(InterChr = inter))
  })

  out <- as.data.frame(rbindlist(lapply(results, as.data.table)))
  # Clean up column names (replace hyphens from SV type labels)
  colnames(out) <- c('sample', 'Trans_Bal', 'Trans_Unbal', 'TandemDup',
                     'Inversion_Bal', 'Inversion_Unbal', 'Deletion', 'InterChr')
  out
}

#' Load per-sample indel counts for a vector of sample names.
#' Returns a data.frame with columns: sample, Deletion, Insertion, ratio.
load_indel_counts <- function(samples, indel_base_path) {
  results <- lapply(samples, function(s) {
    path <- file.path(indel_base_path, 'Indels', 'CombinedIndels',
                      paste0(s, '_CombinedIndels.txt'))
    sv   <- as.data.frame(fread(path, header = TRUE, sep = "\t",
                                 stringsAsFactors = FALSE, na.strings = c(".", "NA")))
    tbl  <- table(sv$type)
    del  <- as.numeric(tbl['Deletion'])
    ins  <- as.numeric(tbl['Insertion'])
    list(sample = s, Deletion = del, Insertion = ins, ratio = del / ins)
  })
  as.data.frame(rbindlist(lapply(results, as.data.table)))
}

#' Generic boxplot with jitter using viridis fill.
plot_boxplot <- function(data, x_var, y_var, title, y_label) {
  ggplot(data, aes_string(x = x_var, y = y_var, fill = x_var)) +
    geom_boxplot() +
    scale_fill_viridis(discrete = TRUE, alpha = 0.6) +
    geom_jitter(color = "black", size = 0.4, alpha = 0.9) +
    theme_ipsum() +
    theme(legend.position = "none",
          plot.title = element_text(size = 11)) +
    ggtitle(title) +
    xlab(x_var) +
    ylab(y_label)
}

#' Fit a mixed-effects model and return the fixed-effect p-value for predictor[2].
lmer_pvalue <- function(formula, data) {
  model <- lmer(formula, data = data)
  coef(summary(model))[, "Pr(>|t|)"][2]
}

# ── 1. Derive Control Samples ─────────────────────────────────────────────────

