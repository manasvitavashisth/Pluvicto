# ── 2a. Statistical tests (mixed model, patient as random effect) ─────────────

sv_metrics <- c('Trans_Bal', 'Trans_Unbal', 'TandemDup',
                 'Inversion_Bal', 'Inversion_Unbal', 'Deletion', 'InterChr')

# p-values across all three groups
sv_pvals_all <- sapply(sv_metrics, function(m) {
  lmer_pvalue(as.formula(paste(m, '~ bal + (1|patient)')), data = sv_all)
})
print(sv_pvals_all)

# p-values for Pluvicto vs. radiation only
sv_pluvicto_vs_rad <- sv_all[sv_all$bal %in% c('pluvicto', 'radiation'), ]
sv_pvals_pvr <- sapply(sv_metrics, function(m) {
  lmer_pvalue(as.formula(paste(m, '~ bal + (1|patient)')), data = sv_pluvicto_vs_rad)
