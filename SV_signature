rownames(sig_mat) <- sv_sig$Samples
sig_mat$pluvicto  <- rownames(sig_mat) %in% pluvicto

# t-test for each RS signature between groups
rs_sigs   <- setdiff(colnames(sig_mat), 'pluvicto')
rs_pvals  <- sapply(rs_sigs, function(s) {
  t.test(sig_mat[[s]] ~ sig_mat$pluvicto)$p.value
})
