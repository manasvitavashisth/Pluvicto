# Pre-computed ctDNA SNV master file (used only for simple sample subsetting
# where force-call files are unavailable)
ctDNA <- read_tsv_df(CTDNA_SNV_PATH)

# PyClone cluster summary (all patients)
clusters_all <- read_tsv_df(CLUSTERS_PATH)

#' Compute bidirectional overlap counts between tumour WGS and each ctDNA
#' timepoint: how many ctDNA variants are in the tumour, and vice versa.
#'
#'
#' @param tum        Tumour SNV data.frame with varID column
#' @param ctdna_list Named list of ctDNA data.frames with varID column
#' @return data.frame: timepoint, n_ctdna_in_tum, n_tum_in_ctdna
compute_bidirectional_overlap <- function(tum, ctdna_list) {
  do.call(rbind, lapply(names(ctdna_list), function(tp) {
    ct <- ctdna_list[[tp]]
    data.frame(
      timepoint       = tp,
      n_ctdna_in_tum  = sum(ct$varID  %in% tum$varID),   # ctDNA variants found in tumour
      n_tum_in_ctdna  = sum(tum$varID %in% ct$varID)      # tumour variants detected in ctDNA
    )
  }))
}

