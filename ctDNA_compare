TIMEPOINT_COLORS <- c(C1 = 'red', C2 = 'yellow', TAN = 'blue')

# ── Helper Functions ──────────────────────────────────────────────────────────

#' Read a tab-separated flat file into a data.frame.
read_tsv_df <- function(path, ...) {
  as.data.frame(fread(path, header = TRUE, sep = "\t",
                      stringsAsFactors = FALSE, na.strings = c(".", "NA"), ...))
}

#' Parse depth and alt-depth fields from a VCF-style Otherinfo13 column
#' and add a variant ID (Chr_Start_Ref_Alt).
#'
#' @param df  data.frame with columns Chr, Start, Ref, Alt, Otherinfo13
#' @return    df with additional columns: depth, alt_depth, varID
parse_variant_fields <- function(df) {
  info_split    <- strsplit(df$Otherinfo13, ':')
  df$depth      <- sapply(info_split, function(x) if (length(x) >= 4) x[4] else NA)
  df$alt_depth  <- sapply(info_split, function(x) if (length(x) >= 4) x[2] else NA)
  df$alt_depth  <- as.numeric(sub(".*,\\s*", "", df$alt_depth))
  df$varID      <- paste(df$Chr, df$Start, df$Ref, df$Alt, sep = '_')
  df
}

#' Load a force-called ctDNA mutation file, parse variant fields, and filter
#' to variants with at least one alt read that are also present in the tumour.
#'
#' @param path       Path to the *_multianno.txt force-call file
#' @param tumour_ids Character vector of tumour varIDs to filter against
#' @return Filtered data.frame
load_force_called_ctdna <- function(path, tumour_ids) {
  df <- read_tsv_df(path) |> parse_variant_fields()
  df <- df[df$alt_depth > 0, ]
  df <- df[df$varID %in% tumour_ids, ]
  df
}

#' Build file paths for C1, C2, and TAN force-call result files for a patient.
#' TAN uses a separate directory (results_force_call_withoutTopOff).
#'
#' @param patient_id  e.g. '22-049'
#' @param tan_id      TAN sample ID from TAN_SAMPLE_IDS
#' @return Named list of file paths: C1, C2, TAN
build_ctdna_paths <- function(patient_id, tan_id, base_ctdna = BASE_CTDNA) {
  list(
    C1  = file.path(base_ctdna, 'PowerAnalysis/results_force_call',
                    paste0(patient_id, '_C1'), 'mutations_unfiltered.hg38_multianno.txt'),
    C2  = file.path(base_ctdna, 'PowerAnalysis/results_force_call',
                    paste0(patient_id, '_C2'), 'mutations_unfiltered.hg38_multianno.txt'),
    TAN = file.path(base_ctdna, 'PowerAnalysis/results_force_call_withoutTopOff',
                    tan_id, 'mutations_unfiltered.hg38_multianno.txt')
  )
}

#' Load all three ctDNA timepoints for a patient.
#'
#' @param patient_id  Patient identifier string
#' @param tumour_ids  varIDs from the tumour WGS data for this patient
#' @return Named list of data.frames: C1, C2, TAN
load_patient_ctdna <- function(patient_id, tumour_ids) {
  paths <- build_ctdna_paths(patient_id, TAN_SAMPLE_IDS[[patient_id]])
  lapply(paths, load_force_called_ctdna, tumour_ids = tumour_ids)
}

#' For each tumour site in a patient, compute the fraction of site-private
#' variants detected in each ctDNA timepoint.
#'
#' Site-private = variants present in one site but absent from all others.
#'
#' @param tum         Tumour SNV data.frame for the patient (has sample_name, varID)
#' @param ctdna_list  Named list of ctDNA data.frames (C1, C2, TAN)
#' @return data.frame: site, timepoint, n_private, n_detected, fraction
compute_site_private_detection <- function(tum, ctdna_list) {
  sites <- unique(tum$sample_name)

  results <- lapply(sites, function(site) {
    site_vars    <- tum$varID[tum$sample_name == site]
    other_vars   <- tum$varID[tum$sample_name != site]
    private_vars <- setdiff(site_vars, other_vars)
    n_private    <- length(private_vars)

    fractions <- sapply(names(ctdna_list), function(tp) {
      sum(ctdna_list[[tp]]$varID %in% private_vars) / n_private
    })

    data.frame(
      site       = site,
      timepoint  = names(fractions),
      n_private  = n_private,
      n_detected = as.integer(fractions * n_private),
      fraction   = fractions,
      row.names  = NULL
    )
  })

  do.call(rbind, results)
}

#' Compute the fraction of PyClone cluster mutations detected in each ctDNA
#' timepoint for a given patient.
#'
#' @param pyclone_path  Path to patient PyClone output TSV
#' @param ctdna_list    Named list of ctDNA data.frames (C1, C2, TAN)
#' @return data.frame: cluster_id, timepoint, n_cluster, n_detected, fraction
compute_cluster_detection <- function(pyclone_path, ctdna_list) {
  pyclone     <- read_tsv_df(pyclone_path)
  cluster_ids <- unique(pyclone$cluster_id)

  results <- lapply(cluster_ids, function(cl) {
    cluster_muts <- unique(pyclone$mutation_id[pyclone$cluster_id == cl])
    n_cluster    <- length(cluster_muts)

    fractions <- sapply(names(ctdna_list), function(tp) {
      sum(ctdna_list[[tp]]$varID %in% cluster_muts) / n_cluster
    })

    data.frame(
      cluster_id = cl,
      timepoint  = names(fractions),
      n_cluster  = n_cluster,
      n_detected = as.integer(fractions * n_cluster),
      fraction   = fractions,
      row.names  = NULL
    )
  })

  do.call(rbind, results)
}

#' Barplot of ctDNA detection fractions, coloured by timepoint.
#'
#' @param fractions  Named numeric vector (names = timepoint labels)
#' @param title      Plot title
plot_detection_barplot <- function(fractions, title = '') {
  barplot(fractions,
          col       = TIMEPOINT_COLORS[names(fractions)],
          names.arg = names(fractions),
          ylim      = c(0, 1),
          main      = title,
          ylab      = 'Fraction Detected')
}

# ── 1. Load Core Data ─────────────────────────────────────────────────────────

# Full tumour SNV master file (all patients)
