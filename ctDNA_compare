# ── 2d. Cluster Annotation Table Update & Scatter Plot (22-049) ──────────────
# Original script manually updated two rows of the cluster annotation table
# with detection fractions (cluster$[cluster_id==5, 7:9] = a) before plotting.
# Here we merge the computed fractions directly rather than patching by index.

cluster_ann_049 <- read_tsv_df(CLUSTERS_PATH)
cluster_ann_049 <- cluster_ann_049[cluster_ann_049$Patient == pt_id, ]

# Pivot cluster_det_049 to wide format (one row per cluster, cols = C1/C2/TAN)
