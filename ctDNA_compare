  cluster_ann_049,
  cluster_det_wide_049,
  by.x = 'Cluster ID', by.y = 'cluster_id', all.x = TRUE
)

# Scatter: TAN detection fraction vs. cellular prevalence, coloured by clone identity
ggplot(cluster_ann_049,
       aes(x = `Cellular Prevalence`, y = TAN, color = `Pyclone Identity`)) +
  geom_point() +
  theme_bw() +
  labs(title = paste(pt_id, 'TAN Detection vs. Cellular Prevalence'),
       x     = 'Cellular Prevalence',
       y     = 'TAN Detection Fraction')

# Long-format scatter: all timepoints vs. cellular prevalence
cluster_long_049 <- do.call(rbind, lapply(c('C1', 'C2', 'TAN'), function(tp) {
  data.frame(
    Overlap            = cluster_ann_049[[tp]],
    CellularPrevalence = cluster_ann_049$`Cellular Prevalence`,
    ctDNA              = tp,
    PycloneIdentity    = cluster_ann_049$`Pyclone Identity`
  )
}))

ggplot(cluster_long_049,
       aes(x = CellularPrevalence, y = Overlap, color = PycloneIdentity)) +
  geom_point() +
  theme_bw() +
  labs(title = paste(pt_id, 'ctDNA Overlap vs. Cellular Prevalence (All Timepoints)'),
       x     = 'Cellular Prevalence',
       y     = 'Fraction Detected',
       color = 'Clone Identity')

