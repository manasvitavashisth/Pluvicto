CTDNA_SNV_PATH <- file.path(BASE_PLUVICTO, 'SNV/MasterSNVFile_ctDNA.txt')
CLUSTERS_PATH  <- file.path(BASE_PYCLONE, 'Clusters.txt')

# Mapping of patient → TAN (cfDNA WGS) sample identifier
