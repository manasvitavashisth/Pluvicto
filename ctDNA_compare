  cluster_det_049[, c('cluster_id', 'timepoint', 'fraction')],
  idvar     = 'cluster_id',
  timevar   = 'timepoint',
  direction = 'wide'
)
colnames(cluster_det_wide_049) <- gsub('fraction\\.', '', colnames(cluster_det_wide_049))

# Merge detected fractions into annotation table
